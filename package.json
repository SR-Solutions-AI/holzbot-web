    "katex": "^0.16.25",
    "lucide-react": "^0.552.0",
    "next": "16.0.1",
    "pdfjs-dist": "^4.0.379",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^29",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.0.1",
    "jest": "^29",
    "jest-environment-jsdom": "^29",
    "tailwindcss": "^4",
    "ts-jest": "^29",
    "tsx": "^4.19.2",
